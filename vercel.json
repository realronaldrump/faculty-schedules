{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "routes": [
    {
      "src": "/",
      "headers": { "Cache-Control": "no-cache" },
      "continue": true
    },
    {
      "src": "/index\\.html",
      "headers": { "Cache-Control": "no-cache" },
      "continue": true
    },
    {
      "src": "/assets/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    { "handle": "filesystem" },
    { "src": "/assets/(.*)", "status": 404 },
    {
      "src": "/(.*)",
      "headers": { "Cache-Control": "no-cache" },
      "dest": "/index.html"
    }
  ]
}
