{
  "name": "hsd-faculty-dashboard",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "Davis's Big Beautiful Dashboard with Normalized Database Structure",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "emulators": "firebase emulators:start",
    "deploy": "firebase deploy",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:firestore": "firebase deploy --only firestore",
    "deploy:indexes": "firebase deploy --only firestore:indexes"
  },
  "dependencies": {
    "dompurify": "^3.0.9",
    "firebase": "^12.15.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.513.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "react-virtualized-auto-sizer": "^2.0.2",
    "react-window": "^1.8.10",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.3.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "firebase-tools": "^15.22.4",
    "globals": "^17.0.0",
    "jsdom": "^23.2.0",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "gaxios": {
      "uuid": "^11.1.1"
    }
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "keywords": [
    "react",
    "firebase",
    "firestore",
    "tailwindcss",
    "faculty-management",
    "scheduling",
    "university",
    "baylor",
    "dashboard"
  ],
  "author": "Private Maintainer",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/hsd-faculty-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/hsd-faculty-dashboard/issues"
  },
  "homepage": "https://your-org.github.io/hsd-faculty-dashboard",
  "license": "MIT"
}
