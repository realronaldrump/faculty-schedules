{
  "id": "baylor-clss-default",
  "version": "1.0.0",
  "description": "Default CLSS CSV mapping profile for Baylor exports.",
  "requiredFields": [
    "clss_id",
    "course_code",
    "section",
    "crn",
    "instructor",
    "term"
  ],
  "fields": {
    "clss_id": { "aliases": ["CLSS ID", "CLSSID", "CLSS Identifier"] },
    "course_code": { "aliases": ["Course", "Course Code"] },
    "section": { "aliases": ["Section #", "Section", "Section Number"] },
    "crn": { "aliases": ["CRN", "Course Reference Number"] },
    "instructor": { "aliases": ["Instructor", "Instructors", "Faculty"] },
    "term": { "aliases": ["Term", "Semester"] },
    "term_code": { "aliases": ["Term Code", "Semester Code"] },
    "course_title": { "aliases": ["Course Title", "Long Title", "Title/Topic"] },
    "meeting_pattern": { "aliases": ["Meeting Pattern", "Meetings"] },
    "room": { "aliases": ["Room", "Location"] },
    "status": { "aliases": ["Status"] },
    "instruction_method": { "aliases": ["Inst. Method", "Instruction Method"] },
    "catalog_number": { "aliases": ["Catalog Number"] },
    "credit_hours": { "aliases": ["Credit Hrs", "Credit Hrs Min", "Credit Hrs Max", "Credits"] },
    "subject_code": { "aliases": ["Subject Code"] },
    "department_code": { "aliases": ["Department Code"] },
    "enrollment": { "aliases": ["Enrollment"] },
    "maximum_enrollment": { "aliases": ["Maximum Enrollment", "Max Enrollment"] },
    "wait_cap": { "aliases": ["Wait Cap"] },
    "wait_total": { "aliases": ["Wait Total"] },
    "open_seats": { "aliases": ["Open Seats"] },
    "wait_available": { "aliases": ["Wait Available"] },
    "reserved_seats": { "aliases": ["Reserved Seats"] },
    "reserved_seats_enrollment": { "aliases": ["Reserved Seats - Enrollment"] },
    "schedule_type": { "aliases": ["Schedule Type"] },
    "part_of_term": { "aliases": ["Part of Semester", "Part of Term"] },
    "campus": { "aliases": ["Campus"] },
    "visible_on_web": { "aliases": ["Visible on Web"] },
    "special_approval": { "aliases": ["Special Approval"] },
    "cross_list_crns": { "aliases": ["Cross-list CRNs", "Cross List", "Cross-listed CRNs"] }
  }
}
